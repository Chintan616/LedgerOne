# OpenRouter API key — get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Model slug as listed on OpenRouter (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# PostgreSQL connection in SQLAlchemy format
# jdbc:postgresql://host:5432/db  →  postgresql+psycopg2://user:pass@host:5432/db
POSTGRES_URL=postgresql+psycopg2://postgres:password@localhost:5432/ledgerone
